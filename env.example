# Copy this file to `.env` (cp env.example .env) and fill in the values.
#
# ---------------------------------------------------------------------------
# Database (Supabase Postgres)
# In Supabase: Project Settings → Database → Connection string
#   DATABASE_URL = "Connection pooling" string (port 6543) + ?pgbouncer=true
#   DIRECT_URL   = "Direct connection" string (port 5432), used for migrations
# ---------------------------------------------------------------------------
# Note: connection_limit=1 is a serverless recommendation, but it starves a
# long-running dev server (and pages that run several queries concurrently),
# causing Prisma P2024 "Timed out fetching a new connection" errors. Use a
# small pool instead.
DATABASE_URL="postgresql://postgres.xxxx:[PASSWORD]@aws-0-region.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=5&pool_timeout=20"
DIRECT_URL="postgresql://postgres.xxxx:[PASSWORD]@aws-0-region.pooler.supabase.com:5432/postgres"

# ---------------------------------------------------------------------------
# Auth.js (NextAuth)
# ---------------------------------------------------------------------------
AUTH_SECRET=            # generate with: openssl rand -base64 32
# Set to your deployed URL in production, e.g. https://rocketcash.vercel.app
AUTH_URL=http://localhost:3000

# Google OAuth (Google Cloud Console → Credentials → OAuth client ID)
# Authorized redirect URI: <AUTH_URL>/api/auth/callback/google
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Comma-separated Google emails allowed to sign in to THIS instance.
# Leave blank to allow any Google account (open self-host default).
# Example: you@example.com,partner@example.com
ALLOWED_EMAILS=

# ---------------------------------------------------------------------------
# Plaid (https://dashboard.plaid.com/developers/keys)
# ---------------------------------------------------------------------------
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox       # sandbox | production
# Public HTTPS URL Plaid can reach (leave blank for local dev without webhooks)
PLAID_WEBHOOK_URL=

# ---------------------------------------------------------------------------
# Cron protection — checked in /api/plaid/sync
# ---------------------------------------------------------------------------
CRON_SECRET=            # any random string; openssl rand -hex 32

# ---------------------------------------------------------------------------
# Token encryption — encrypts Plaid access tokens at rest
# ---------------------------------------------------------------------------
ENCRYPTION_KEY=         # generate with: openssl rand -base64 32
